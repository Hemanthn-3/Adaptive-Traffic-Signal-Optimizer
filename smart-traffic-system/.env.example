# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme_super_secret_key_here
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=traffic_pass
POSTGRES_DB=traffic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://traffic_user:traffic_pass@postgres:5432/traffic_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0

# ─── MQTT (Mosquitto) ─────────────────────────────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_pass
MQTT_CLIENT_ID=traffic_backend

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ─── ML / YOLOv8 ──────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=yolov8n.pt
VEHICLE_CLASSES=2,3,5,7
MAX_LANE_CAPACITY=20
FRAME_SKIP=5

# ─── Signal Timing ────────────────────────────────────────────────────────────
MIN_GREEN_DURATION=10
MAX_GREEN_DURATION=50
DEFAULT_YELLOW_DURATION=3
EMERGENCY_GREEN_DURATION=90
