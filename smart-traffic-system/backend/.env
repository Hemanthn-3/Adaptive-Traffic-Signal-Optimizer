# ──────────────────────────────────────────────────────────────────────────────
# smart-traffic-system backend configuration
# ──────────────────────────────────────────────────────────────────────────────

# Application Environment
APP_ENV=development
SECRET_KEY=your-secret-key-change-me
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://traffic_user:traffic_pass@localhost:5432/traffic_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=traffic_backend

# ML Model Configuration
YOLO_MODEL_PATH=yolov8n.pt
VEHICLE_CLASSES=2,3,5,7
MAX_LANE_CAPACITY=20
FRAME_SKIP=5

# Signal Timing (seconds)
MIN_GREEN_DURATION=10
MAX_GREEN_DURATION=50
DEFAULT_YELLOW_DURATION=3
EMERGENCY_GREEN_DURATION=90

# Emergency Vehicle Detection
EMERGENCY_DETECTION_CONFIDENCE=0.7
EMERGENCY_AUTO_CLEAR_SECONDS=60
EMERGENCY_RED_THRESHOLD=15
EMERGENCY_YELLOW_THRESHOLD=15
EMERGENCY_MIN_WIDTH_RATIO=0.15

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
